{
  "description": "Forbidden words and patterns for professional cover letters. Avoids AI jargon, identifiers, and unprofessional language.",
  "forbidden_words": {
    "ai_jargon": [
      "AI-powered",
      "AI-driven",
      "machine learning",
      "algorithms",
      "leveraging AI",
      "cutting-edge AI",
      "neural networks",
      "deep learning",
      "natural language processing",
      "data-driven culture",
      "synergy",
      "paradigm shift",
      "disruptive"
    ],
    "overused_buzzwords": [
      "impact",
      "innovative",
      "passionate about",
      "excited to",
      "dynamic",
      "fast-paced",
      "collaborative",
      "think outside the box",
      "move the needle",
      "circle back",
      "low-hanging fruit",
      "pivot",
      "game-changer",
      "take it to the next level",
      "bring to the table"
    ],
    "vague_terms": [
      "things",
      "stuff",
      "nice to have",
      "etc.",
      "and so on",
      "somehow",
      "basically",
      "literally",
      "actually",
      "quite",
      "very",
      "really",
      "very much",
      "kind of",
      "sort of"
    ],
    "empty_phrases": [
      "as mentioned",
      "as you can see",
      "it goes without saying",
      "needless to say",
      "at the end of the day",
      "in this day and age",
      "in today's world",
      "cutting edge",
      "best practices"
    ]
  },
  "forbidden_patterns": {
    "dashes": {
      "description": "Avoid em-dashes (—) and en-dashes (–). Use parentheses or rewrite sentences instead.",
      "pattern": "[–—]",
      "replacement": "Use parentheses or semicolons"
    },
    "identifiers": {
      "description": "Avoid technical identifiers, tech-specific jargon that sounds too robotistic",
      "avoid": [
        "microservices architectures",
        "distributed systems",
        "event-driven",
        "serverless",
        "containerization",
        "orchestration",
        "horizontal scaling",
        "vertical scaling",
        "async/await",
        "REST APIs",
        "GraphQL",
        "gRPC",
        "DDD",
        "CQRS",
        "saga pattern",
        "circuit breaker",
        "load balancing"
      ],
      "why": "Too technical for a cover letter. Use plain English equivalents."
    },
    "excessive_technical_depth": {
      "description": "Avoid going too deep into technical details that don't serve the narrative",
      "avoid": [
        "goroutines and channels",
        "worker pools",
        "FIFO async flows",
        "Step Functions",
        "SQS and SNS",
        "DynamoDB",
        "Elasticsearch",
        "ClickHouse",
        "observability tools",
        "distributed tracing"
      ],
      "context": "Mention technologies briefly, but focus on business impact, not implementation details."
    }
  },
  "style_guidelines": {
    "tone": [
      "Professional yet conversational",
      "Confident without arrogance",
      "Specific and concrete, not vague",
      "Focus on impact and business value, not technical details"
    ],
    "sentence_structure": [
      "Avoid run-on sentences",
      "Use active voice",
      "Avoid multiple nested clauses",
      "Keep sentences under 20 words when possible"
    ],
    "punctuation": [
      "No em-dashes (—) or en-dashes (–)",
      "Use commas, semicolons, or parentheses instead",
      "No excessive exclamation marks",
      "Avoid ellipses (...)"
    ]
  },
  "checklist": {
    "content": [
      "Does the letter show genuine interest in the company?",
      "Are specific accomplishments highlighted with metrics?",
      "Are values aligned with company mission?",
      "Is the tone professional yet personable?"
    ],
    "language": [
      "No AI jargon or buzzwords",
      "No vague terms (things, stuff, nice to have)",
      "No em-dashes or en-dashes",
      "No excessive technical jargon",
      "All sentences are clear and direct",
      "No clichés or empty phrases"
    ],
    "length": [
      "Cover letter is 3-5 paragraphs",
      "Each paragraph is 3-5 sentences",
      "Total length is approximately 300-400 words"
    ]
  }
